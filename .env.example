# The real LLM API this gateway forwards clean traffic to.
# OpenAI: https://api.openai.com   |   Anthropic: https://api.anthropic.com
# Ollama / vLLM / LM Studio: e.g. http://localhost:11434
UPSTREAM_BASE_URL=https://api.openai.com

# Optional. If set, the gateway injects this key upstream and your clients need
# NO key of their own (useful for a shared/sandbox deployment). Leave blank for
# bring-your-own-key mode: each client sends its own Authorization header and the
# gateway passes it straight through.
UPSTREAM_API_KEY=

# Address the gateway listens on.
LISTEN_ADDR=0.0.0.0:9003

# Set to "true" to also BLOCK requests that match a MITRE ATLAS technique.
# Default (false) logs ATLAS matches but only blocks on DLP / jailbreak /
# injection / agentic-abuse hits — ATLAS is broad and better as detection.
ATLAS_BLOCK=false

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info
